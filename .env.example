# LangSmith Configuration
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Para descobrir seu username: publique qualquer prompt no LangSmith Hub, depois abra-o e clique no ícone de cadeado (🔒) para ver seu username.
USERNAME_LANGSMITH_HUB=

# OpenAI Configuration
OPENAI_API_KEY=

# Google Gemini Configuration
GOOGLE_API_KEY=

# LLM Configuration
LLM_PROVIDER=google
LLM_MODEL=gemini-3.1-flash-lite
EVAL_MODEL=gemini-3.1-flash-lite

#LLM_PROVIDER=openai
#LLM_MODEL=gpt-4o-mini
#EVAL_MODEL=gpt-4o

# Rate Limit Sleep - pausa quando o numero de chamadas acumuladas passar do threshold,
# para nao estourar a cota gratuita da API (erro 429 ResourceExhausted)
RATE_LIMIT_SLEEP_ENABLED=false
RATE_LIMIT_SLEEP_CALL_THRESHOLD=12
RATE_LIMIT_SLEEP_SECONDS=60